{
  "name": "heicraft",
  "version": "0.1.1",
  "description": "Modern HEIC/HEIF conversion toolkit for JavaScript and TypeScript.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/ragnarok22/heicraft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragnarok22/heicraft.git"
  },
  "bugs": {
    "url": "https://github.com/ragnarok22/heicraft/issues"
  },
  "keywords": [
    "heic",
    "heif",
    "jpeg",
    "jpg",
    "png",
    "webp",
    "convert",
    "image",
    "browser",
    "node",
    "typescript"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "browser": {
    "node:fs/promises": "./dist/browser/fs-promises.js",
    "sharp": "./dist/browser/sharp.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "coverage": "vitest run --coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm run build",
    "smoke:browser": "node scripts/smoke-browser.mjs",
    "smoke:dist": "node -e \"import('./dist/index.js').then((mod) => { const exports = ['convertHeic', 'isHeic', 'detectHeic', 'getHeicInfo', 'HeicraftError', 'InvalidInputError', 'UnsupportedFormatError', 'ConversionError', 'AbortError']; for (const name of exports) { if (!(name in mod)) throw new Error('Missing export ' + name); } })\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "heic-decode": "^2.1.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=18.18"
  }
}
